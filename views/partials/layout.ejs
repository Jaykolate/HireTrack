<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HireTrack</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <a href="/" class="logo">HireTrack</a>
    <div class="nav-links">
      <a href="/">Dashboard</a>
      <% if (typeof userName !== 'undefined' && userName) { %>
        <a href="/applications/new">Add new</a>
        <span class="nav-user"><%= userName %></span>
        <button id="sign-out-btn" class="nav-sign-out">Sign out</button>
      <% } else { %>
        <a href="/sign-in" class="nav-auth-link">Login</a>
        <a href="/sign-up" class="nav-auth-btn">Sign up</a>
      <% } %>
    </div>
  </nav>

  <main class="container">
    <%- body %>
  </main>

  <% if (typeof clerkPublishableKey !== 'undefined' && clerkPublishableKey) { %>
  <script
    async
    crossorigin="anonymous"
    data-clerk-publishable-key="<%= clerkPublishableKey %>"
    src="https://cdn.jsdelivr.net/npm/@clerk/clerk-js@5/dist/clerk.browser.js"
    type="text/javascript"
  ></script>
  <script>
    window.addEventListener('load', async function () {
      await window.Clerk.load();
      var btn = document.getElementById('sign-out-btn');
      if (btn) {
        btn.addEventListener('click', async function () {
          await window.Clerk.signOut();
          window.location.href = '/sign-in';
        });
      }
    });
  </script>
  <% } %>
</body>
</html>